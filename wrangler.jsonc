{
  "name": "strangeways-dev",
  "compatibility_date": "2025-12-13",
  "$schema": "./node_modules/wrangler/config-schema.json",
  "observability": {
    "enabled": true,
  },
  "pages_build_output_dir": "./dist",
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "strangeways-dev",
    },
  ],
}
