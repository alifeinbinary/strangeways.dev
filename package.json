{
  "name": "strangeways.dev",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "vitest",
    "deploy": "pnpm run build && node -e \"const fs=require('fs');const p='dist/wrangler.json';const j=JSON.parse(fs.readFileSync(p,'utf8'));delete j.assets;fs.writeFileSync(p,JSON.stringify(j));\" && wrangler pages deploy dist",
    "cf-typegen": "wrangler types"
  },
